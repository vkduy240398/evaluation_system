{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "assets": [
      {
        "include": "../src/static",
        "outDir": "dist",
        "watchAssets": false
      },
      {
        "include": "../pdf",
        "outDir": "dist/pdf",
        "watchAssets": false
      }
    ],
    "watchAssets": false
  }
}
